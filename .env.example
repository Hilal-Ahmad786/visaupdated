# ============================================================================
# VİS VİZE — Environment Variables (Part 1)
# Copy to .env.local and fill in real values. Never commit real secrets.
# ============================================================================

# --- Public site ---
# Canonical production origin (no trailing slash). Used for metadata, sitemap,
# canonical URLs and Open Graph absolute URLs.
NEXT_PUBLIC_SITE_URL="https://www.visvize.com"

# --- Contact details (placeholders until verified — see docs/CONTENT_PLACEHOLDERS.md) ---
NEXT_PUBLIC_PHONE_DISPLAY="0850 000 00 00"
NEXT_PUBLIC_PHONE_E164="+908500000000"
NEXT_PUBLIC_WHATSAPP_DISPLAY="0500 000 00 00"
NEXT_PUBLIC_WHATSAPP_E164="905000000000"
NEXT_PUBLIC_CONTACT_EMAIL="info@visvize.com"

# --- Analytics & tracking (Part 2 admin will manage these; env is the fallback) ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
NEXT_PUBLIC_GTM_ID=""
NEXT_PUBLIC_GOOGLE_ADS_ID=""
# Conversion label that fires only on a verified successful lead.
NEXT_PUBLIC_ADS_LEAD_CONVERSION_LABEL=""

# --- Server-side: lead handling ---
# Comma-separated allowlist of admin notification recipients.
LEAD_NOTIFY_TO=""
# Transactional email provider (e.g. Resend / Postmark). Leave blank to disable
# email and only persist leads. Set the API key in the secret manager, not here.
EMAIL_PROVIDER=""
EMAIL_API_KEY=""
EMAIL_FROM="VİS VİZE <no-reply@visvize.com>"

# --- Security ---
# Secret used to sign thank-you submission tokens (HMAC). Generate a long random value.
SUBMISSION_TOKEN_SECRET="change-me-in-production"
# Simple in-memory rate-limit window can be overridden per deploy.
RATE_LIMIT_MAX="5"
RATE_LIMIT_WINDOW_MS="60000"

# --- Database (Part 2 — when CMS/lead storage is connected) ---
DATABASE_URL=""
