# ============================================================================
# VİS VİZE — Environment Variables (Part 1)
# Copy to .env.local and fill in real values. Never commit real secrets.
# ============================================================================

# --- Public site ---
# Canonical production origin (no trailing slash). Used for metadata, sitemap,
# canonical URLs and Open Graph absolute URLs.
NEXT_PUBLIC_SITE_URL="https://www.visvize.com"

# --- Contact details (placeholders until verified — see docs/CONTENT_PLACEHOLDERS.md) ---
NEXT_PUBLIC_PHONE_DISPLAY="444 84 72"
NEXT_PUBLIC_PHONE_E164="4448472"
NEXT_PUBLIC_WHATSAPP_DISPLAY="0552 128 84 72"
NEXT_PUBLIC_WHATSAPP_E164="905521288472"
NEXT_PUBLIC_CONTACT_EMAIL="info@visvize.com"

# --- Analytics & tracking ---
# Google Tag Manager is the SINGLE tag manager. GA4 and Google Ads tags live
# INSIDE GTM and are fired from the site's structured `vis_*` dataLayer events.
# The site does NOT load gtag.js directly and does NOT hardcode GA4/Ads ids or
# conversion labels — see docs/tracking-setup.md.
NEXT_PUBLIC_GTM_ID="GTM-XXXXXXX"
# Microsoft Clarity project id — heatmaps + session replay. Empty = off.
NEXT_PUBLIC_CLARITY_ID=""
#
# LEGACY (no longer read by the app — GA4/Ads are configured in GTM now). Kept
# here only as a reminder; safe to leave blank/remove.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=""
# NEXT_PUBLIC_GOOGLE_ADS_ID=""
# NEXT_PUBLIC_ADS_LEAD_CONVERSION_LABEL=""
# NEXT_PUBLIC_ADS_CALL_CONVERSION_LABEL=""
# NEXT_PUBLIC_ADS_WHATSAPP_CONVERSION_LABEL=""

# --- Server-side: lead handling ---
# Comma-separated allowlist of admin notification recipients.
LEAD_NOTIFY_TO=""
# Transactional email provider (e.g. Resend / Postmark). Leave blank to disable
# email and only persist leads. Set the API key in the secret manager, not here.
EMAIL_PROVIDER=""
EMAIL_API_KEY=""
EMAIL_FROM="VİS VİZE <no-reply@visvize.com>"

# --- Security ---
# Secret used to sign thank-you submission tokens (HMAC). Generate a long random value.
SUBMISSION_TOKEN_SECRET="change-me-in-production"
# Simple in-memory rate-limit window can be overridden per deploy.
RATE_LIMIT_MAX="5"
RATE_LIMIT_WINDOW_MS="60000"

# --- Admin authentication ---
# Bootstrap admin account. On first login it is seeded (with a scrypt-hashed
# password) into the admin_users table. No admin credentials are hardcoded in
# source — set these here / in the secret manager.
ADMIN_SEED_EMAIL="admin@example.com"
ADMIN_SEED_PASSWORD="change-me-strong-password"
ADMIN_SEED_NAME="Site Yöneticisi"
# Secret used to sign the admin session cookie (HMAC). Long random value.
ADMIN_SESSION_SECRET="change-me-in-production"

# --- Database (Part 2 — when CMS/lead storage is connected) ---
# Also used by first-party click tracking. This site uses its OWN Neon Postgres
# DB. After setting this, run `npm run db:push` to create the click_events table.
DATABASE_URL=""

# --- First-party click tracking ---
# Salt/pepper for hashing visitor IPs before storage (never store raw IPs).
# Set a long random value in production; defaults to a constant if unset.
CLICK_PEPPER=""
